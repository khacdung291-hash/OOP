#P1
minutes = 42
seconds = 42
total_seconds = minutes * 60 + seconds
print("1. Total seconds :", total_seconds)
#P2
km = 10
km_per_mile = 1.61
miles = km / km_per_mile
print("2. Miles in 10 km:", miles)
time_seconds = total_seconds
seconds_per_mile = time_seconds / miles
pace_minutes = int(seconds_per_mile // 60)
pace_seconds = seconds_per_mile % 60
hours = time_seconds / 3600
mph = miles / hours
print("3. Average pace:", pace_minutes, "minutes", round(pace_seconds,2), "seconds per mile")
print("   Average speed:", round(mph,2), "miles per hour")
